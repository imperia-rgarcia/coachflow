@model MyApp.Models.RoutineInputModel

@{
    ViewData["Title"] = "Routine Creator";
    string? successMessage = TempData["RoutineSaved"] as string;
}

<section class="mx-auto max-w-5xl space-y-10 text-white">
    <header class="space-y-2">
        <h1 class="text-3xl font-semibold">Creador de rutinas</h1>
        <p class="text-sm text-gray-300">Define el nombre de la rutina, sus fases y los días que se repetirán en cada microciclo.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="rounded-lg border border-emerald-400/40 bg-emerald-500/10 p-4 text-sm text-emerald-100">
            @successMessage
        </div>
    }

    <form asp-action="RoutineCreator" method="post" class="space-y-8">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-sm text-rose-300"></div>

        <section class="space-y-3 rounded-lg border border-white/10 bg-gray-900/60 p-6">
            <label class="flex flex-col gap-2">
                <span class="text-sm font-medium text-indigo-200">Nombre de la rutina</span>
                <input asp-for="Name" placeholder="Rutina de fuerza para Carlos" class="rounded-md border border-white/10 bg-gray-950/70 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
            </label>
            <span asp-validation-for="Name" class="text-xs text-rose-300"></span>
        </section>

        <section class="space-y-4 rounded-lg border border-white/10 bg-gray-900/60 p-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-semibold">Fases de la rutina</h2>
                    <p class="text-sm text-gray-300">Escribe el nombre de cada fase e indica cuántos microciclos la componen.</p>
                </div>
                <button type="button" id="add-phase" class="inline-flex items-center gap-2 rounded-md border border-indigo-400/60 px-3 py-1.5 text-sm font-medium text-indigo-200 transition hover:border-indigo-300 hover:text-indigo-100">
                    <span class="inline-flex size-5 items-center justify-center rounded-full bg-indigo-500/30 text-indigo-200">+</span>
                    Añadir fase
                </button>
            </div>

            <div id="phase-list" class="space-y-4">
                @for (int index = 0; index < Model.Phases.Count; index++)
                {
                    int displayIndex = index + 1;
                    <div class="space-y-2 rounded-md border border-white/10 bg-gray-950/70 p-4" data-phase-row="true">
                        <div class="grid gap-3 md:grid-cols-[2fr,1fr]">
                            <label class="flex flex-col gap-2">
                                <span class="text-sm font-medium text-indigo-200">Fase @displayIndex</span>
                                <input asp-for="Phases[index].Name" placeholder="Fase de adaptación" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                            </label>
                            <label class="flex flex-col gap-2">
                                <span class="text-sm font-medium text-indigo-200">Microciclos</span>
                                <input asp-for="Phases[index].Microcycles" min="1" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                            </label>
                        </div>
                        <div class="grid gap-2 md:grid-cols-[2fr,1fr]">
                            <span asp-validation-for="Phases[index].Name" class="text-xs text-rose-300"></span>
                            <span asp-validation-for="Phases[index].Microcycles" class="text-xs text-rose-300"></span>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="space-y-4 rounded-lg border border-white/10 bg-gray-900/60 p-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-semibold">Días del microciclo</h2>
                    <p class="text-sm text-gray-300">Estos nombres se aplicarán a todos los microciclos de la rutina.</p>
                </div>
                <button type="button" id="add-day" class="inline-flex items-center gap-2 rounded-md border border-indigo-400/60 px-3 py-1.5 text-sm font-medium text-indigo-200 transition hover:border-indigo-300 hover:text-indigo-100">
                    <span class="inline-flex size-5 items-center justify-center rounded-full bg-indigo-500/30 text-indigo-200">+</span>
                    Añadir día
                </button>
            </div>

            <div id="day-list" class="space-y-3">
                @for (int dayIndex = 0; dayIndex < Model.MicrocycleDays.Count; dayIndex++)
                {
                    int displayDay = dayIndex + 1;
                    <div class="space-y-2 rounded-md border border-white/10 bg-gray-950/70 p-4" data-day-row="true">
                        <label class="flex flex-col gap-2">
                            <span class="text-sm font-medium text-indigo-200">Día @displayDay</span>
                            <input asp-for="MicrocycleDays[dayIndex]" placeholder="Día @displayDay - Sesión" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                        </label>
                        <span asp-validation-for="MicrocycleDays[dayIndex]" class="text-xs text-rose-300"></span>
                    </div>
                }
            </div>
        </section>

        <div class="flex items-center justify-end">
            <button type="submit" class="rounded-md bg-indigo-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-400">Guardar rutina</button>
        </div>
    </form>
</section>

<script type="text/template" id="phase-template">
    <div class="space-y-2 rounded-md border border-white/10 bg-gray-950/70 p-4" data-phase-row="true">
        <div class="grid gap-3 md:grid-cols-[2fr,1fr]">
            <label class="flex flex-col gap-2">
                <span class="text-sm font-medium text-indigo-200">Fase __display__</span>
                <input id="Phases___index____Name" name="Phases[__index__].Name" placeholder="Fase de hipertrofia" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
            </label>
            <label class="flex flex-col gap-2">
                <span class="text-sm font-medium text-indigo-200">Microciclos</span>
                <input id="Phases___index____Microcycles" name="Phases[__index__].Microcycles" type="number" min="1" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
            </label>
        </div>
        <div class="grid gap-2 md:grid-cols-[2fr,1fr]">
            <span class="text-xs text-rose-300" data-valmsg-for="Phases[__index__].Name" data-valmsg-replace="true"></span>
            <span class="text-xs text-rose-300" data-valmsg-for="Phases[__index__].Microcycles" data-valmsg-replace="true"></span>
        </div>
    </div>
</script>

<script type="text/template" id="day-template">
    <div class="space-y-2 rounded-md border border-white/10 bg-gray-950/70 p-4" data-day-row="true">
        <label class="flex flex-col gap-2">
            <span class="text-sm font-medium text-indigo-200">Día __display__</span>
            <input id="MicrocycleDays___index__" name="MicrocycleDays[__index__]" placeholder="Día __display__ - Sesión" class="rounded-md border border-white/10 bg-gray-900/80 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
        </label>
        <span class="text-xs text-rose-300" data-valmsg-for="MicrocycleDays[__index__]" data-valmsg-replace="true"></span>
    </div>
</script>

@section Scripts {
    <script>
        (function () {
            const phaseList = document.getElementById("phase-list");
            const dayList = document.getElementById("day-list");
            const addPhaseButton = document.getElementById("add-phase");
            const addDayButton = document.getElementById("add-day");
            const phaseTemplate = document.getElementById("phase-template").innerHTML.trim();
            const dayTemplate = document.getElementById("day-template").innerHTML.trim();
            let phaseIndex = phaseList.querySelectorAll('[data-phase-row="true"]').length;
            let dayIndex = dayList.querySelectorAll('[data-day-row="true"]').length;

            function addPhaseRow() {
                const indexValue = phaseIndex.toString();
                const displayValue = (phaseIndex + 1).toString();
                let html = phaseTemplate.replace(/__index__/g, indexValue);
                html = html.replace(/__display__/g, displayValue);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html;
                const element = wrapper.firstElementChild;
                if (element) {
                    phaseList.appendChild(element);
                    phaseIndex += 1;
                }
            }

            function addDayRow() {
                const indexValue = dayIndex.toString();
                const displayValue = (dayIndex + 1).toString();
                let html = dayTemplate.replace(/__index__/g, indexValue);
                html = html.replace(/__display__/g, displayValue);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html;
                const element = wrapper.firstElementChild;
                if (element) {
                    dayList.appendChild(element);
                    dayIndex += 1;
                }
            }

            if (addPhaseButton) {
                addPhaseButton.addEventListener("click", function (event) {
                    event.preventDefault();
                    addPhaseRow();
                });
            }

            if (addDayButton) {
                addDayButton.addEventListener("click", function (event) {
                    event.preventDefault();
                    addDayRow();
                });
            }
        })();
    </script>
}
