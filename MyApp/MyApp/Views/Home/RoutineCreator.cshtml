@{
    ViewData["Title"] = "Routine Creator";
}

<section class="space-y-10">
    <header class="space-y-2">
        <p class="text-sm uppercase tracking-[0.2em] text-indigo-300">Constructor de rutinas</p>
        <h1 class="text-4xl font-semibold text-white">Define la estructura de tu rutina</h1>
        <p class="text-base text-gray-300">Completa la información básica, especifica las fases con sus microciclos y define los días que compondrán cada microciclo.</p>
    </header>

    <form class="space-y-10 rounded-2xl border border-white/10 bg-gray-900/40 p-8 shadow-xl shadow-indigo-500/10">
        <section class="space-y-4">
            <h2 class="text-lg font-semibold text-white">Información general</h2>
            <label class="flex flex-col gap-2">
                <span class="text-sm font-medium text-indigo-200">Nombre de la rutina</span>
                <input type="text" name="routineName" placeholder="Rutina de fuerza para Carlos" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
            </label>
        </section>

        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-white">Fases de la rutina</h2>
                <button id="add-phase" type="button" class="inline-flex items-center gap-2 rounded-lg border border-indigo-400/60 px-3 py-1.5 text-sm font-medium text-indigo-200 transition hover:border-indigo-300 hover:text-indigo-100">
                    <span class="inline-flex size-5 items-center justify-center rounded-full bg-indigo-500/30 text-indigo-200">+</span>
                    Añadir fase
                </button>
            </div>
            <p class="text-sm text-gray-400">Especifica el nombre de cada fase y el número de microciclos que tendrá.</p>
            <div id="phase-list" class="space-y-4">
                <div class="grid gap-3 md:grid-cols-[2fr,1fr] md:items-end">
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-indigo-200">Nombre de la fase</span>
                        <input type="text" name="phaseName[]" placeholder="Fase de adaptación" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-sm font-medium text-indigo-200">Microciclos</span>
                        <input type="number" name="phaseMicrocycles[]" min="1" placeholder="2" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                    </label>
                </div>
            </div>
        </section>

        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-lg font-semibold text-white">Días del microciclo</h2>
                <button id="add-day" type="button" class="inline-flex items-center gap-2 rounded-lg border border-indigo-400/60 px-3 py-1.5 text-sm font-medium text-indigo-200 transition hover:border-indigo-300 hover:text-indigo-100">
                    <span class="inline-flex size-5 items-center justify-center rounded-full bg-indigo-500/30 text-indigo-200">+</span>
                    Añadir día
                </button>
            </div>
            <p class="text-sm text-gray-400">Estos nombres se aplicarán a cada microciclo de la rutina.</p>
            <div id="day-list" class="space-y-3">
                <label class="flex flex-col gap-2">
                    <span class="text-sm font-medium text-indigo-200">Día 1</span>
                    <input type="text" name="microcycleDay[]" placeholder="Día 1 - Pecho" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                </label>
                <label class="flex flex-col gap-2">
                    <span class="text-sm font-medium text-indigo-200">Día 2</span>
                    <input type="text" name="microcycleDay[]" placeholder="Día 2 - Pierna" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                </label>
                <label class="flex flex-col gap-2">
                    <span class="text-sm font-medium text-indigo-200">Día 3</span>
                    <input type="text" name="microcycleDay[]" placeholder="Día 3 - Descanso" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                </label>
                <label class="flex flex-col gap-2">
                    <span class="text-sm font-medium text-indigo-200">Día 4</span>
                    <input type="text" name="microcycleDay[]" placeholder="Día 4 - Torso" class="rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40" />
                </label>
            </div>
        </section>

        <div class="flex justify-end">
            <button type="submit" class="rounded-lg bg-indigo-500 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 transition hover:bg-indigo-400">Guardar estructura</button>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        (function () {
            const phaseList = document.getElementById("phase-list");
            const addPhaseButton = document.getElementById("add-phase");
            const dayList = document.getElementById("day-list");
            const addDayButton = document.getElementById("add-day");

            if (addPhaseButton) {
                addPhaseButton.addEventListener("click", function (event) {
                    event.preventDefault();

                    const wrapper = document.createElement("div");
                    wrapper.className = "grid gap-3 md:grid-cols-[2fr,1fr] md:items-end";

                    const nameLabel = document.createElement("label");
                    nameLabel.className = "flex flex-col gap-2";

                    const nameSpan = document.createElement("span");
                    nameSpan.className = "text-sm font-medium text-indigo-200";
                    nameSpan.textContent = "Nombre de la fase";

                    const nameInput = document.createElement("input");
                    nameInput.type = "text";
                    nameInput.name = "phaseName[]";
                    nameInput.placeholder = "Fase de hipertrofia";
                    nameInput.className = "rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40";

                    nameLabel.appendChild(nameSpan);
                    nameLabel.appendChild(nameInput);

                    const microcycleLabel = document.createElement("label");
                    microcycleLabel.className = "flex flex-col gap-2";

                    const microcycleSpan = document.createElement("span");
                    microcycleSpan.className = "text-sm font-medium text-indigo-200";
                    microcycleSpan.textContent = "Microciclos";

                    const microcycleInput = document.createElement("input");
                    microcycleInput.type = "number";
                    microcycleInput.name = "phaseMicrocycles[]";
                    microcycleInput.min = "1";
                    microcycleInput.placeholder = "3";
                    microcycleInput.className = "rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40";

                    microcycleLabel.appendChild(microcycleSpan);
                    microcycleLabel.appendChild(microcycleInput);

                    wrapper.appendChild(nameLabel);
                    wrapper.appendChild(microcycleLabel);

                    phaseList.appendChild(wrapper);
                });
            }

            if (addDayButton) {
                addDayButton.addEventListener("click", function (event) {
                    event.preventDefault();

                    const dayCount = dayList.querySelectorAll("label").length + 1;
                    const label = document.createElement("label");
                    label.className = "flex flex-col gap-2";

                    const span = document.createElement("span");
                    span.className = "text-sm font-medium text-indigo-200";
                    span.textContent = "Día " + dayCount.toString();

                    const input = document.createElement("input");
                    input.type = "text";
                    input.name = "microcycleDay[]";
                    input.placeholder = "Día " + dayCount.toString() + " - Nueva sesión";
                    input.className = "rounded-lg border border-white/10 bg-gray-950/60 px-3 py-2 text-sm text-white placeholder:text-gray-500 focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-400/40";

                    label.appendChild(span);
                    label.appendChild(input);

                    dayList.appendChild(label);
                });
            }
        })();
    </script>
}
